{
  "name": "who-made-what",
  "version": "1.0.0",
  "description": "Git repository contribution report — who produces what",
  "type": "module",
  "bin": {
    "who-made-what": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "server/src/",
    "client/dist/"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/src/index.js",
    "dev:client": "npm run build:client -- --mode development",
    "build:client": "vite build --config client/vite.config.js",
    "build": "vite build --config client/vite.config.js",
    "prepublishOnly": "npm run build",
    "start": "node bin/cli.js"
  },
  "keywords": [
    "git",
    "contribution",
    "report",
    "dashboard",
    "analytics",
    "commits",
    "authors",
    "heatmap",
    "activity"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "^6.1.0",
    "@mui/joy": "^5.0.0-beta.48",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.0",
    "vite": "^5.4.0"
  }
}
