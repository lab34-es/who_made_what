{
  "name": "@lab34-es/who_made_what",
  "version": "0.0.4",
  "description": "Git repository contribution report — who produces what",
  "type": "module",
  "bin": {
    "who_made_what": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "server/src/",
    "client/dist/"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/src/index.js",
    "dev:client": "npm run build:client -- --mode development",
    "build:client": "vite build --config client/vite.config.js",
    "build": "vite build --config client/vite.config.js",
    "prepublishOnly": "npm run build",
    "start": "node bin/cli.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage"
  },
  "keywords": [
    "git",
    "contribution",
    "report",
    "dashboard",
    "analytics",
    "commits",
    "authors",
    "heatmap",
    "activity"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lab34/who_made_what.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@jest/globals": "^30.3.0",
    "@mui/icons-material": "^7.3.9",
    "@mui/joy": "^5.0.0-beta.52",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "jest": "^30.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0",
    "vite": "^7.3.1"
  }
}
